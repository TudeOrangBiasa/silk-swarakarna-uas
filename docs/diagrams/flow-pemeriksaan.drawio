          <mxGeometry x="180" y="80" width="40" height="60" as="geometry" />
        </mxCell>

        <mxCell id="getPemeriksaan" value="GET /pemeriksaan" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;" vertex="1" parent="1">

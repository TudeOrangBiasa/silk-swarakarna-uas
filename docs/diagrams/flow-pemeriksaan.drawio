        <mxCell id="e_b3_3" value="" style="endArrow=classic;html=1;sketch=1;curved=1;strokeColor=#5c3a1e;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="b3_p3" target="b3_txn">
          <mxGeometry relative="1" as="geometry" />

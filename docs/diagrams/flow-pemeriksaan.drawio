        <!-- BRANCH 1: LIST (x=385, w=220)                                    -->
        <!-- ================================================================ -->
        <mxCell id="b1_label" value="List (default)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontStyle=1;fontColor=#5c3a1e;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="390" y="465" width="210" height="30" as="geometry" />
        </mxCell>
        <mxCell id="b1_p1" value="PemeriksaanPresenter::getListData()" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="385" y="510" width="220" height="45" as="geometry" />
        </mxCell>
        <mxCell id="b1_p2" value="Pemeriksaan::readWithJoin()" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="385" y="575" width="220" height="45" as="geometry" />
        </mxCell>
        <mxCell id="b1_p3" value="PemeriksaanQuery::findAllJoined($keyword)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="385" y="640" width="220" height="45" as="geometry" />
        </mxCell>
        <mxCell id="b1_db" value="SELECT p.*, ps.nama_pasien,&#xa;d.nama_dokter, l.nama_layanan&#xa;FROM pemeriksaan p&#xa;JOIN pasien ps ON p.id_pasien=ps.id_pasien&#xa;JOIN dokter d ON p.id_dokter=d.id_dokter&#xa;JOIN layanan l ON p.id_layanan=l.id_layanan" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#def0dc;strokeColor=#5c8a49;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="385" y="705" width="220" height="75" as="geometry" />
        </mxCell>
        <mxCell id="b1_view" value="views/pemeriksaan/index.php&#xa;(Bootstrap table + status badge&#xa;bg-warning / bg-info / bg-success)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="385" y="800" width="220" height="55" as="geometry" />
        </mxCell>
        <mxCell id="b1_end" value="200 OK (data list)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#def0dc;strokeColor=#5c8a49;sketch=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="385" y="875" width="220" height="40" as="geometry" />

        <!-- ================================================================ -->
        <!-- BRANCH 3: UPDATE STATUS — STATE MACHINE (x=960, w=270)           -->
        <!-- ================================================================ -->
        <mxCell id="b3_label" value="Update Status (State Machine)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontStyle=1;fontColor=#5c3a1e;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="960" y="465" width="270" height="30" as="geometry" />
        </mxCell>
        <mxCell id="b3_p1" value="User klik tombol 'Mulai' / 'Selesai'" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="960" y="510" width="270" height="45" as="geometry" />
        </mxCell>
        <mxCell id="b3_p2" value="POST /pemeriksaan/update_status&#xa;(par: id_periksa, status_pemeriksaan)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="960" y="575" width="270" height="45" as="geometry" />
        </mxCell>
        <mxCell id="b3_p3" value="Router handler&#xa;→ Pemeriksaan::updateStatus(\$id, \$newStatus)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="960" y="640" width="270" height="45" as="geometry" />
        </mxCell>
        <mxCell id="b3_txn" value="BEGIN TRANSACTION" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="705" width="270" height="40" as="geometry" />
        </mxCell>
        <mxCell id="b3_db_lock" value="PemeriksaanQuery::findStatusForUpdate(\$id)&#xa;SELECT status_pemeriksaan FROM pemeriksaan&#xa;WHERE id_periksa = ? FOR UPDATE&#xa;(row-level lock)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#def0dc;strokeColor=#5c8a49;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="960" y="765" width="270" height="65" as="geometry" />
        </mxCell>

        <!-- State Machine Decision -->
        <mxCell id="b3_decision" value="Transisi status&#xa;valid?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff4cc;strokeColor=#b8901a;sketch=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="995" y="855" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- B3 — Invalid transition branch (left) -->
        <mxCell id="b3_inv1" value="throw RuntimeException&#xa;(invalid transition)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="900" y="985" width="210" height="45" as="geometry" />
        </mxCell>
        <mxCell id="b3_inv2" value="ROLLBACK" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;sketch=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="1050" width="210" height="40" as="geometry" />
        </mxCell>
        <mxCell id="b3_inv3" value="flash_error:&#xa;'Transisi tidak valid'" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="900" y="1110" width="210" height="45" as="geometry" />
        </mxCell>

        <!-- B3 — Valid transition branch (right) -->
        <mxCell id="b3_val1" value="PemeriksaanRepository::updateStatus()&#xa;UPDATE pemeriksaan SET status_pemeriksaan = ?&#xa;WHERE id_periksa = ?" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1080" y="985" width="270" height="55" as="geometry" />
        </mxCell>
        <mxCell id="b3_val2" value="COMMIT" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#def0dc;strokeColor=#5c8a49;sketch=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1080" y="1060" width="270" height="40" as="geometry" />
        </mxCell>
        <mxCell id="b3_val3" value="set flash_success:&#xa;'Status berhasil diperbarui'" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1080" y="1120" width="270" height="45" as="geometry" />
        </mxCell>

        <!-- B3 — Converge to redirect -->
        <mxCell id="b3_end" value="302 Redirect &#10;/pemeriksaan" style="ellipse;whiteSpace=wrap;html=1;fillColor=#def0dc;strokeColor=#5c8a49;sketch=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="970" y="1195" width="280" height="40" as="geometry" />
        </mxCell>

        <!-- B3 edges: linear flow up to decision -->
        <mxCell id="e_d_b3" value="Update Status" style="endArrow=classic;html=1;sketch=1;curved=1;strokeColor=#5c3a1e;strokeWidth=2;exitX=1;exitY=0.62;entryX=0;entryY=0.5;fontSize=11;fontStyle=1;fontColor=#5c8a49;fontFamily=Helvetica;" edge="1" parent="1" source="actionDecision" target="b3_p1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_b3_1" value="" style="endArrow=classic;html=1;sketch=1;curved=1;strokeColor=#5c3a1e;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="b3_p1" target="b3_p2">
          <mxGeometry relative="1" as="geometry" />

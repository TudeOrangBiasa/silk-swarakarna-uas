        <mxCell id="1" parent="0" />

        <!-- ====== TITLE ====== -->
        <mxCell id="title" value="Flow Pemeriksaan (State Machine) — SILK-Swarakarna" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#5c3a1e;sketch=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="600" y="20" width="1000" height="40" as="geometry" />

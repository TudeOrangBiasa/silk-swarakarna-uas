          <mxGeometry x="665" y="1065" width="230" height="45" as="geometry" />
        </mxCell>
        <mxCell id="b2_end" value="302 Redirect" style="ellipse;whiteSpace=wrap;html=1;fillColor=#def0dc;strokeColor=#5c8a49;sketch=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="665" y="1130" width="230" height="40" as="geometry" />

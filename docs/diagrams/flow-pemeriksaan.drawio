        <!-- BRANCH 2: CREATE (x=665, w=230)                                  -->
        <!-- ================================================================ -->
        <mxCell id="b2_label" value="Create" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontStyle=1;fontColor=#5c3a1e;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="670" y="465" width="220" height="30" as="geometry" />
        </mxCell>
        <mxCell id="b2_p1" value="Klik 'Tambah Pemeriksaan'&#xa;GET /pemeriksaan/create" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="665" y="510" width="230" height="45" as="geometry" />
        </mxCell>
        <mxCell id="b2_form" value="Form dengan 3 dropdown:&#xa;• PasienOptions (via PasienPresenter)&#xa;• DokterOptions (via DokterPresenter)&#xa;• LayananOptions (via LayananPresenter)&#xa;Fields: id_pasien, id_dokter, id_layanan,&#xa;tanggal_periksa (min=today, default=today), keluhan" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="665" y="575" width="230" height="75" as="geometry" />
        </mxCell>
        <mxCell id="b2_p2" value="Submit form&#xa;POST /pemeriksaan" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="665" y="670" width="230" height="45" as="geometry" />
        </mxCell>
        <mxCell id="b2_p3" value="Router handler&#xa;→ Pemeriksaan::create(\$_POST)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="665" y="735" width="230" height="45" as="geometry" />
        </mxCell>
        <mxCell id="b2_decision" value="Validasi 5 required:&#xa;id_pasien, id_dokter,&#xa;id_layanan, tgl_periksa,&#xa;keluhan" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff4cc;strokeColor=#b8901a;sketch=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="705" y="800" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b2_p4" value="generateKodeOtomatis()&#xa;→ TRX-YYYYNNN (per year)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="665" y="905" width="230" height="45" as="geometry" />
        </mxCell>
        <mxCell id="b2_db" value="INSERT INTO pemeriksaan&#xa;(id_periksa, id_pasien, id_dokter,&#xa;id_layanan, tanggal_periksa,&#xa;keluhan, status_pemeriksaan)&#xa;VALUES (?, ?, ?, ?, ?, ?, 'Menunggu')" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#def0dc;strokeColor=#5c8a49;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="665" y="970" width="230" height="75" as="geometry" />

        <mxCell id="title" value="SILK-Swarakarna — Entity Relationship Diagram&#xa;&#xa;3 master (pasien, dokter, layanan) + 1 transaksi (pemeriksaan) — Kardinalitas 1:N dari masing-masing master ke pemeriksaan" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#5c3a1e;sketch=1;fontFamily=Helvetica;" vertex="1" parent="1">

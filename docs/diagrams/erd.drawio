        </mxCell>

        <mxCell id="pasien" value="&lt;b&gt;pasien&lt;/b&gt;&lt;hr&gt;PK · id_pasien &lt;i&gt;VARCHAR(20)&lt;/i&gt;&lt;br&gt;No Rekam Medis, format RM-XXX&lt;br&gt;&lt;br&gt;nama_pasien &lt;i&gt;VARCHAR(100)&lt;/i&gt;&lt;br&gt;tanggal_lahir &lt;i&gt;DATE&lt;/i&gt;&lt;br&gt;no_hp &lt;i&gt;VARCHAR(20)&lt;/i&gt;&lt;br&gt;alamat &lt;i&gt;TEXT&lt;/i&gt;&lt;br&gt;created_at · updated_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe4b5;strokeColor=#b8651e;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;sketch=1;fontFamily=Helvetica;fontSize=12;shadow=1;" vertex="1" parent="1">

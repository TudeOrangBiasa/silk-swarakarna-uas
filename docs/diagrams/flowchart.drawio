          <mxGeometry x="600" y="650" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e10" value="Tidak" style="endArrow=classic;html=1;sketch=1;curved=1;strokeColor=#a53d3d;strokeWidth=2;dashed=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=11;fontStyle=1;fontColor=#a53d3d;fontFamily=Helvetica;" edge="1" parent="1" source="decision" target="notfound">

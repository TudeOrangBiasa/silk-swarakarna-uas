<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="Flow" id="flow-silk-swarakarna">
    <mxGraphModel dx="900" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1150" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="SILK-Swarakarna — Request Flow (PHP Native OOP)&#xa;&#xa;Alur hidup sebuah HTTP request: browser → front controller → bootstrap → router → domain class → MySQL → view → response" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#5c3a1e;sketch=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="60" y="20" width="730" height="60" as="geometry" />
        </mxCell>

        <mxCell id="start" value="Mulai&#xa;(User buka browser)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#def0dc;strokeColor=#5c8a49;sketch=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="110" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="user" value="Admin / Resepsionis&#xa;klik menu atau submit form" style="shape=umlActor;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;html=1;outlineConnect=0;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="120" y="110" width="60" height="80" as="geometry" />
        </mxCell>

        <mxCell id="browser" value="Browser&#xa;kirim HTTP request&#xa;(GET/POST ke URL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#7b4397;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="280" y="220" width="280" height="60" as="geometry" />
        </mxCell>

        <mxCell id="apachenginx" value="Apache / Nginx&#xa;(DDEV: nginx-fpm)&#xa;rewrite URL → public/index.php" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#7b4397;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="280" y="320" width="280" height="60" as="geometry" />
        </mxCell>

        <mxCell id="frontcontroller" value="public/index.php&#xa;(Front Controller + Router)&#xa;lihat URI → tentukan route" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="420" width="280" height="60" as="geometry" />
        </mxCell>

        <mxCell id="bootstrap" value="includes/bootstrap.php&#xa;· session_start()&#xa;· load includes/config.php&#xa;· require composer autoload&#xa;· set error handler" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="280" y="520" width="280" height="80" as="geometry" />
        </mxCell>

        <mxCell id="decision" value="Route&#xa;match?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff4cc;strokeColor=#b8901a;sketch=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="640" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="classinstance" value="Instantiate class&#xa;mis. new Pasien()&#xa;panggil method (create/read/...)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="280" y="760" width="280" height="60" as="geometry" />
        </mxCell>

        <mxCell id="db" value="Database (MariaDB / MySQL)&#xa;eksekusi prepared statement&#xa;return rows / affected count" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#def0dc;strokeColor=#5c8a49;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="280" y="860" width="280" height="80" as="geometry" />
        </mxCell>

        <mxCell id="view" value="views/pasien/index.php&#xa;(atau view terkait)&#xa;render HTML + Tailwind" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="280" y="980" width="280" height="60" as="geometry" />
        </mxCell>

        <mxCell id="response" value="HTML response&#xa;kirim balik ke browser" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#7b4397;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="280" y="1080" width="280" height="50" as="geometry" />

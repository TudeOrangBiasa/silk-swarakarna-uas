          <mxGeometry x="904" y="410" width="12" height="900" as="geometry" />
        </mxCell>

        <!-- ========== COMMON PREFIX: STEPS 1-9 ========== -->

        <!-- Step 1 -->
        <mxCell id="s1" value="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#5c3a1e;sketch=0;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="m1" value="POST /pemeriksaan/update_status&#xa;(id, newStatus)" style="html=1;verticalAlign=bottom;endArrow=block;sketch=1;curved=1;strokeColor=#5c3a1e;strokeWidth=2;fontSize=12;fontFamily=Helvetica;" edge="1" parent="1" source="admin" target="router">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="180" y="230" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 2 -->
        <mxCell id="s2" value="2" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#5c3a1e;sketch=0;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="40" y="280" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="m2" value="updateStatus(id, newStatus)" style="html=1;verticalAlign=bottom;endArrow=block;sketch=1;curved=1;strokeColor=#5c3a1e;strokeWidth=2;fontSize=12;fontFamily=Helvetica;" edge="1" parent="1" source="router" target="periksa">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="340" y="290" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 3: self-call — constructor -->
        <mxCell id="s3" value="3" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#5c3a1e;sketch=0;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="40" y="340" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="m3" value="Database::getInstance()&#xa;(constructor)" style="html=1;verticalAlign=bottom;endArrow=block;sketch=1;curved=1;strokeColor=#5c3a1e;strokeWidth=2;fontSize=12;fontStyle=2;fontFamily=Helvetica;" edge="1" parent="1" source="periksa" target="periksa">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="380" y="355" />
              <mxPoint x="400" y="355" />
              <mxPoint x="400" y="375" />
              <mxPoint x="380" y="375" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 4 -->
        <mxCell id="s4" value="4" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#5c3a1e;sketch=0;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="40" y="400" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="m4" value="beginTransaction()" style="html=1;verticalAlign=bottom;endArrow=block;sketch=1;curved=1;strokeColor=#5c3a1e;strokeWidth=2;fontSize=12;fontFamily=Helvetica;" edge="1" parent="1" source="periksa" target="db">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="660" y="410" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 5 -->
        <mxCell id="s5" value="5" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#5c3a1e;sketch=0;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="40" y="460" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="m5" value="findStatusForUpdate(id)" style="html=1;verticalAlign=bottom;endArrow=block;sketch=1;curved=1;strokeColor=#5c3a1e;strokeWidth=2;fontSize=12;fontFamily=Helvetica;" edge="1" parent="1" source="periksa" target="query">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="500" y="470" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 6 -->
        <mxCell id="s6" value="6" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#5c3a1e;sketch=0;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="40" y="520" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="m6" value="SELECT status_pemeriksaan&#xa;FROM pemeriksaan&#xa;WHERE id_periksa = ?&#xa;FOR UPDATE" style="html=1;verticalAlign=bottom;endArrow=block;sketch=1;curved=1;strokeColor=#5c3a1e;strokeWidth=2;fontSize=12;fontFamily=Helvetica;" edge="1" parent="1" source="query" target="db">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="740" y="530" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 7: return -->
        <mxCell id="s7" value="7" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#5c3a1e;sketch=0;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="40" y="580" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="m7" value="current status&#xa;(e.g. &quot;Menunggu&quot;)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;sketch=1;curved=1;strokeColor=#8b7355;strokeWidth=2;fontSize=12;fontStyle=2;fontColor=#8b7355;fontFamily=Helvetica;" edge="1" parent="1" source="db" target="query">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="740" y="590" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 8: return -->
        <mxCell id="s8" value="8" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#5c3a1e;sketch=0;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="40" y="640" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="m8" value="?string" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;sketch=1;curved=1;strokeColor=#8b7355;strokeWidth=2;fontSize=12;fontStyle=2;fontColor=#8b7355;fontFamily=Helvetica;" edge="1" parent="1" source="query" target="periksa">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="500" y="650" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 9: self-call — internal validation -->
        <mxCell id="s9" value="9" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#5c3a1e;sketch=0;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="40" y="700" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="m9" value="validateTransition(current, new)" style="html=1;verticalAlign=bottom;endArrow=block;sketch=1;curved=1;strokeColor=#5c3a1e;strokeWidth=2;fontSize=12;fontStyle=2;fontFamily=Helvetica;" edge="1" parent="1" source="periksa" target="periksa">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="380" y="715" />
              <mxPoint x="400" y="715" />
              <mxPoint x="400" y="735" />
              <mxPoint x="380" y="735" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ========== ALT/ELSE COMBINED FRAGMENT ========== -->

        <!-- Alt frame (outer dashed box) -->
        <mxCell id="alt-frame" value="alt [valid transition]" style="shape=umlFrame;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1e7e34;dashed=1;sketch=1;fontSize=11;fontStyle=1;fontColor=#1e7e34;fontFamily=Helvetica;width=30;height=20;" vertex="1" parent="1">
          <mxGeometry x="40" y="770" width="920" height="730" as="geometry" />
        </mxCell>

        <!-- Else divider line -->
        <mxCell id="else-divider" value="" style="line;strokeWidth=1;fillColor=none;dashed=1;strokeColor=#a53d3d;sketch=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="1210" width="870" height="10" as="geometry" />
        </mxCell>

        <!-- Else label -->
        <mxCell id="else-label" value="else [invalid transition]" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#a53d3d;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="50" y="1200" width="220" height="20" as="geometry" />
        </mxCell>

        <!-- ===== ALT SUCCESS PATH: STEPS 10-12 ===== -->

        <!-- Step 10a: Pemeriksaan → Repository -->
        <mxCell id="s10" value="10" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#1e7e34;sketch=0;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="40" y="790" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="m10a" value="updateStatus(id, newStatus)" style="html=1;verticalAlign=bottom;endArrow=block;sketch=1;curved=1;strokeColor=#1e7e34;strokeWidth=2;fontSize=12;fontFamily=Helvetica;" edge="1" parent="1" source="periksa" target="repo">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="580" y="800" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 10b: Repository → DB -->
        <mxCell id="m10b" value="UPDATE pemeriksaan&#xa;SET status_pemeriksaan = ?&#xa;WHERE id_periksa = ?" style="html=1;verticalAlign=bottom;endArrow=block;sketch=1;curved=1;strokeColor=#1e7e34;strokeWidth=2;fontSize=12;fontFamily=Helvetica;" edge="1" parent="1" source="repo" target="db">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="820" y="860" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 10c: DB → Repository (return) -->
        <mxCell id="m10c" value="affected rows (int)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;sketch=1;curved=1;strokeColor=#1e7e34;strokeWidth=2;fontSize=12;fontStyle=2;fontColor=#1e7e34;fontFamily=Helvetica;" edge="1" parent="1" source="db" target="repo">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="820" y="920" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 10d: Repository → Pemeriksaan (return) -->
        <mxCell id="m10d" value="int" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;sketch=1;curved=1;strokeColor=#1e7e34;strokeWidth=2;fontSize=12;fontStyle=2;fontColor=#1e7e34;fontFamily=Helvetica;" edge="1" parent="1" source="repo" target="periksa">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="580" y="980" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 10e: Pemeriksaan → DB commit -->
        <mxCell id="m10e" value="commit()" style="html=1;verticalAlign=bottom;endArrow=block;sketch=1;curved=1;strokeColor=#1e7e34;strokeWidth=2;fontSize=12;fontFamily=Helvetica;" edge="1" parent="1" source="periksa" target="db">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="660" y="1040" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 11: Pemeriksaan → Router (return) -->
        <mxCell id="s11" value="11" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#1e7e34;sketch=0;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="40" y="1090" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="m11" value="int (affected count)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;sketch=1;curved=1;strokeColor=#1e7e34;strokeWidth=2;fontSize=12;fontStyle=2;fontColor=#1e7e34;fontFamily=Helvetica;" edge="1" parent="1" source="periksa" target="router">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="340" y="1100" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 12: Router → User redirect -->
        <mxCell id="s12" value="12" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#1e7e34;sketch=0;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="40" y="1150" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="m12" value="302 redirect /pemeriksaan&#xa;+ flash_success" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;sketch=1;curved=1;strokeColor=#1e7e34;strokeWidth=2;fontSize=12;fontStyle=2;fontColor=#1e7e34;fontFamily=Helvetica;" edge="1" parent="1" source="router" target="admin">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="180" y="1160" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ===== ELSE ERROR PATH: STEPS 13a-13d ===== -->

        <!-- Step 13a: self-call — throw -->
        <mxCell id="s13" value="13" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#a53d3d;sketch=0;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="40" y="1240" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="m13a" value="throw new RuntimeException(&quot;Invalid status&#xa;transition: X -> Y&quot;)" style="html=1;verticalAlign=bottom;endArrow=block;sketch=1;curved=1;strokeColor=#a53d3d;strokeWidth=2;fontSize=12;fontStyle=2;fontFamily=Helvetica;" edge="1" parent="1" source="periksa" target="periksa">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="380" y="1260" />
              <mxPoint x="400" y="1260" />
              <mxPoint x="400" y="1280" />
              <mxPoint x="380" y="1280" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 13b: Pemeriksaan → DB rollback -->
        <mxCell id="m13b" value="rollBack()&#xa;(auto via Throwable catch)" style="html=1;verticalAlign=bottom;endArrow=block;sketch=1;curved=1;strokeColor=#a53d3d;strokeWidth=2;fontSize=12;fontFamily=Helvetica;" edge="1" parent="1" source="periksa" target="db">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="660" y="1310" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 13c: Pemeriksaan → Router (throws) -->
        <mxCell id="m13c" value="throws" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;sketch=1;curved=1;strokeColor=#a53d3d;strokeWidth=2;fontSize=12;fontStyle=2;fontColor=#a53d3d;fontFamily=Helvetica;" edge="1" parent="1" source="periksa" target="router">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="340" y="1370" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 13d: Router → User redirect error -->
        <mxCell id="m13d" value="302 redirect to referer&#xa;+ flash_error" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;sketch=1;curved=1;strokeColor=#a53d3d;strokeWidth=2;fontSize=12;fontStyle=2;fontColor=#a53d3d;fontFamily=Helvetica;" edge="1" parent="1" source="router" target="admin">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="180" y="1430" />
            </Array>
          </mxGeometry>
        </mxCell>


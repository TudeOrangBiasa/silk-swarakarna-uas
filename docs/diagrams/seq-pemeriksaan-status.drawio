          <mxGeometry x="380" y="100" width="100" height="1500" as="geometry" />
        </mxCell>

        <!-- 4. PemeriksaanQuery -->
        <mxCell id="query" value="PemeriksaanQuery" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#e1d5f0;strokeColor=#7c5aa0;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="100" width="100" height="1500" as="geometry" />
        </mxCell>

        <!-- 5. PemeriksaanRepository -->
        <mxCell id="repo" value="PemeriksaanRepository" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#ffe6cc;strokeColor=#d77332;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="100" width="100" height="1500" as="geometry" />

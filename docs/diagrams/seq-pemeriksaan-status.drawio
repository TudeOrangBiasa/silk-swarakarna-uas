        <!-- 6. Database (MariaDB) -->
        <mxCell id="db" value="Database&#xa;(MariaDB)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#def0dc;strokeColor=#5c8a49;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="100" width="100" height="1500" as="geometry" />

        <!-- A_start: Start node -->
        <mxCell id="A_start" value="Mulai" style="ellipse;whiteSpace=wrap;html=1;fillColor=#def0dc;strokeColor=#5c8a49;sketch=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="220" height="40" as="geometry" />

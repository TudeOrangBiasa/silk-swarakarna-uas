        <!-- ================================================================ -->

        <!-- P1: updateStatus -->
        <mxCell id="P1" value="Pemeriksaan::updateStatus(&#xa;  \$id, \$newStatus)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;sketch=1;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">

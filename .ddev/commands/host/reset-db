#!/bin/bash
#ddev-generated
## Description: Reset the project database to a clean state (drops + re-imports schema)
## Usage: ddev reset-db

set -e

if [ ! -f database/silk_swarakarna.sql ]; then
  echo "ERROR: database/silk_swarakarna.sql not found"
  exit 1
fi

echo "Dropping all tables in '${DB_NAME:-silk_swarakarna}'..."
ddev mysql -e "SET FOREIGN_KEY_CHECKS=0; $(grep -E '^DROP TABLE' database/silk_swarakarna.sql | sed 's/;$//' | tr '\n' ' ') ; SET FOREIGN_KEY_CHECKS=1;" 2>/dev/null || true
ddev mysql -e "USE ${DB_NAME:-silk_swarakarna}; SHOW TABLES;" | tail -n +2 | xargs -I {} ddev mysql -e "USE ${DB_NAME:-silk_swarakarna}; DROP TABLE IF EXISTS \`{}\`;" 2>/dev/null || true

echo "Re-importing database/silk_swarakarna.sql..."
ddev mysql < database/silk_swarakarna.sql
echo "✓ Database reset successfully."
